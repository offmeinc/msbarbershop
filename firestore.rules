rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isStaff() {
      return isSignedIn() && (getUserData().role == 'manager' || getUserData().role == 'barber' || getUserData().role == 'developer');
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }

    // Payments
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Working Hours
    match /workingHours/{workId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Staff Notifications
    match /staff_notifications/{docId} {
      allow read, write: if true;
    }

    // Internal Chats
    match /internal_chats/{msgId} {
      allow read, write: if isStaff();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read, write: if isSignedIn();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    // Debts
    match /debts/{debtId} {
      allow read, write: if isSignedIn();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Promotions
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if hasRole('manager') || hasRole('developer');
    }

    // Portfolio
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Client Support Chats
    match /chats/{userId} {
      allow read, write: if true;
      match /{document=**} {
        allow read, write: if true;
      }
    }

    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read, write: if true;
    }

    // Push Subscriptions
    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    // Legacy/Migration support
    match /client_profiles/{loginCode} { allow read, write: if true; }
    match /notifications/{docId} { allow read, write: if true; }
    match /blocked_times/{docId} { allow read, write: if true; }
    
    // App Logs
    match /app_logs/{logId} {
      allow create: if true;
      allow read: if hasRole('developer');
      allow update, delete: if hasRole('developer');
    }
  }
}
