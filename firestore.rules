rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read, write: if true; // Keeping open for simplicity with login codes, but usually involves auth checks
    }

    // Payments
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Working Hours
    match /workingHours/{workId} {
      allow read: if true;
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Staff Notifications
    match /staff_notifications/{docId} {
      allow read, write: if true;
    }

    // Internal Chats
    match /internal_chats/{msgId} {
      allow read, write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Inventory
    match /inventory/{itemId} {
      allow read, write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Debts
    match /debts/{debtId} {
      allow read, write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Promotions
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // Portfolio
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber');
    }

    // Client Support Chats
    match /chats/{userId}/{document=**} {
      allow read, write: if true;
    }

    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read, write: if true;
    }

    // Push Subscriptions
    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    // Legacy/Migration support (Keep for stability)
    match /client_profiles/{loginCode} { allow read, write: if true; }
    match /notifications/{docId} { allow read, write: if true; }
    match /blocked_times/{docId} { allow read, write: if true; }
  }
}
