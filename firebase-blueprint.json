{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data for clients, barbers, and managers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "barber", "manager"] },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Types of services offered by the barbershop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "price", "duration"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booking records for haircuts and other services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "totalPrice": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "loginCode": { "type": "string" }
      },
      "required": ["clientId", "barberId", "serviceId", "date", "status"]
    },
    "WorkingHours": {
      "title": "WorkingHours",
      "description": "Definition of working hours for a barber.",
      "type": "object",
      "properties": {
        "dayOfWeek": { "type": "number", "description": "0 = Sunday, 1 = Monday, ..., 6 = Saturday" },
        "startTime": { "type": "string", "description": "HH:MM format" },
        "endTime": { "type": "string", "description": "HH:MM format" },
        "isActive": { "type": "boolean" }
      },
      "required": ["dayOfWeek", "startTime", "endTime"]
    },
    "Review": {
      "title": "Review",
      "description": "Reviews and ratings for completed appointments.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "clientId": { "type": "string" },
        "barberId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "clientId", "barberId", "rating"]
    },
    "StaffNotification": {
      "title": "StaffNotification",
      "description": "Real-time notifications for the barbershop staff.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["booking", "cancellation", "update"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "clientId": { "type": "string" },
        "appointmentId": { "type": "string" }
      },
      "required": ["type", "message", "timestamp", "read"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Discount codes or special offers.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "serviceIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["code", "discountPercentage", "active"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles."
    },
    "/staff_notifications/{notifId}": {
      "schema": "StaffNotification",
      "description": "Storage for staff notifications."
    },
    "/workingHours/{workId}": {
      "schema": "WorkingHours",
      "description": "Defined working hours for barbers."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Catalog of services."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments scheduled by clients."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews and ratings."
    },
    "/internal_chats/{msgId}": {
      "schema": { "type": "object", "properties": { "text": { "type": "string" }, "senderId": { "type": "string" }, "senderName": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Staff internal chat messages."
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Storage for promotional codes."
    },
    "/chats/{userId}/messages/{msgId}": {
      "schema": { "type": "object", "properties": { "text": { "type": "string" }, "userId": { "type": "string" }, "sender": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Client support chat messages."
    }
  }
}
