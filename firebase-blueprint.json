{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data for clients, barbers, and managers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "barber", "manager"] },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "monthlyGoal": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Image gallery of barber's work.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl"]
    },
    "Service": {
      "title": "Service",
      "description": "Types of services offered by the barbershop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "price", "duration"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booking records for haircuts and other services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "totalPrice": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "loginCode": { "type": "string" },
        "reminderSent": { "type": "boolean" },
        "twoHourReminderSent": { "type": "boolean" }
      },
      "required": ["clientId", "barberId", "serviceId", "date", "status"]
    },
    "WorkingHours": {
      "title": "WorkingHours",
      "description": "Definition of working hours for a barber.",
      "type": "object",
      "properties": {
        "dayOfWeek": { "type": "number", "description": "0 = Sunday, 1 = Monday, ..., 6 = Saturday" },
        "startTime": { "type": "string", "description": "HH:MM format" },
        "endTime": { "type": "string", "description": "HH:MM format" },
        "isActive": { "type": "boolean" }
      },
      "required": ["dayOfWeek", "startTime", "endTime"]
    },
    "Review": {
      "title": "Review",
      "description": "Reviews and ratings for completed appointments.",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "clientId": { "type": "string" },
        "barberId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "clientId", "barberId", "rating"]
    },
    "StaffNotification": {
      "title": "StaffNotification",
      "description": "Real-time notifications for the barbershop staff.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["booking", "cancellation", "update"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "clientId": { "type": "string" },
        "appointmentId": { "type": "string" }
      },
      "required": ["type", "message", "timestamp", "read"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Discount codes or special offers.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "serviceIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["code", "discountPercentage", "active"]
    },
    "PushSubscription": {
      "title": "PushSubscription",
      "description": "Browser Web Push subscription metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userRole": { "type": "string" },
        "endpoint": { "type": "string" },
        "keys": {
          "type": "object",
          "properties": {
            "p256dh": { "type": "string" },
            "auth": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "endpoint", "keys"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Barbershop operational and maintenance expenses.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "value", "category", "date"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Barbershop customer outstanding debts (fiados).",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "value": { "type": "number" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "value", "date"]
    },
    "Settings": {
      "title": "Settings",
      "description": "General barbershop settings like monthly goals and loyalty parameters.",
      "type": "object",
      "properties": {
        "monthlyGoal": { "type": "number" },
        "loyaltyMultiplier": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["monthlyGoal", "loyaltyMultiplier"]
    }
  },
  "firestore": {
    "/debts/{debtId}": {
      "schema": "Debt",
      "description": "Customers debts (fiados) records."
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global barbershop settings."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Barbershop expenses records."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles."
    },
    "/push_subscriptions/{subId}": {
      "schema": "PushSubscription",
      "description": "Push notification subscriptions mapped to user and role."
    },
    "/staff_notifications/{notifId}": {
      "schema": "StaffNotification",
      "description": "Storage for staff notifications."
    },
    "/workingHours/{workId}": {
      "schema": "WorkingHours",
      "description": "Defined working hours for barbers."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Catalog of services."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments scheduled by clients."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews and ratings."
    },
    "/internal_chats/{msgId}": {
      "schema": { "type": "object", "properties": { "text": { "type": "string" }, "senderId": { "type": "string" }, "senderName": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Staff internal chat messages."
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Storage for promotional codes."
    },
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Storage for portfolio images."
    },
    "/chats/{userId}/messages/{msgId}": {
      "schema": { "type": "object", "properties": { "text": { "type": "string" }, "userId": { "type": "string" }, "sender": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Client support chat messages."
    }
  }
}
